{
  "luci-app-mycoflow": {
    "description": "Grant access to MycoFlow ubus methods",
    "read": {
      "file": {
        "/tmp/myco_state.json": ["read"],
        "/sbin/logread": ["exec"]
      },
      "ubus": {
        "myco": ["status", "policy_get", "persona_list"]
      },
      "uci": [
        "mycoflow"
      ]
    },
    "write": {
      "ubus": {
        "myco": [
          "policy_set",
          "policy_boost",
          "policy_throttle",
          "persona_add",
          "persona_delete"
        ]
      },
      "uci": [
        "mycoflow"
      ]
    }
  }
}
